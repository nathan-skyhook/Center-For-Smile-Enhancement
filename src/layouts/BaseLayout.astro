---
import '../styles/global.css';
import SEOHead from '../components/SEOHead.astro';
import StructuredData from '../components/StructuredData.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'Boutique dental care in Minnetonka, MN. Dr. Michael Sudit, DDS — 35+ years of clinical excellence and Disney-inspired patient service.',
  image,
  noindex = false,
} = Astro.props;

const organizationData = {
  name: "Center for Smile Enhancement",
  alternateName: "Dr. Michael Sudit, DDS",
  url: "https://www.drsudit.com",
  logo: new URL('/images/logo-banner.jpg', Astro.site).href,
  telephone: "+19525939310",
  email: "TheCenterforSmileEnhancement@PDPSmiles.com",
  address: {
    "@type": "PostalAddress",
    streetAddress: "10500 Wayzata Blvd.",
    addressLocality: "Minnetonka",
    addressRegion: "MN",
    postalCode: "55305",
    addressCountry: "US",
  },
  openingHours: ["Mo-Th 08:00-17:00", "Fr 08:00-12:00"],
  priceRange: "$$$$",
  medicalSpecialty: "Dentistry",
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Lato:wght@300;400;500&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />

    <meta name="theme-color" content="#1e3460" />

    <SEOHead
      title={title}
      description={description}
      image={image}
      noindex={noindex}
    />

    <StructuredData type="LocalBusiness" data={organizationData} />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <slot />
  </body>
</html>
