---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const services = [
  {
    name: 'General & Family Dentistry',
    description: 'Preventive cleanings, exams, fillings, and whole-family care for all ages.',
    href: '/services/general-family-dentistry/',
    photo: '/images/service-family.jpg',
    photoAlt: 'Mother and child brushing teeth together',
  },
  {
    name: 'Cosmetic Dentistry',
    description: 'ZOOM whitening, porcelain veneers, bonding, and complete smile transformations.',
    href: '/services/cosmetic-dentistry/',
    photo: '/images/service-cosmetic-smile.png',
    photoAlt: 'Woman with a confident, beautiful smile',
  },
  {
    name: 'Orthodontics',
    description: 'Invisalign clear aligners for teens and adults — no metal brackets.',
    href: '/services/orthodontics/',
    photo: '/images/service-orthodontics.png',
    photoAlt: 'Patient placing an Invisalign clear aligner',
  },
  {
    name: 'Implant Dentistry',
    description: 'Permanent tooth replacement with natural-looking, long-lasting dental implants.',
    href: '/services/implant-dentistry/',
    photo: '/images/service-cosmetic.jpg',
    photoAlt: 'Patient with a beautiful, confident smile after restorative dental care',
  },
  {
    name: 'Masterpiece Aesthetics',
    description: 'Botox, dermal fillers, microneedling, and medical-grade skincare services.',
    href: '/services/masterpiece-aesthetics/',
    photo: '/images/service-aesthetics.png',
    photoAlt: 'Woman with refreshed, elegant appearance',
  },
  {
    name: 'TMJ & Facial Pain',
    description: 'Expert diagnosis and treatment for jaw pain, TMJ disorders, and facial discomfort.',
    href: '/services/tmj-facial-pain/',
    photo: '/images/service-tmj.png',
    photoAlt: 'Patient experiencing relief from jaw and facial pain',
  },
  {
    name: 'Emergency Care',
    description: 'Same-day and after-hours care for dental emergencies. Call us at 952-593-9310.',
    href: '/services/emergency-care/',
    photo: '/images/service-emergency.png',
    photoAlt: 'Child with a surprised expression needing dental care',
  },
  {
    name: 'Teledentistry',
    description: 'Connect with Dr. Sudit remotely for consultations, follow-ups, and advice.',
    href: '/services/teledentistry/',
    photo: '/images/service-teledentistry.png',
    photoAlt: 'Patient connecting with dentist via smartphone',
  },
  {
    name: 'Advanced Technology',
    description: 'State-of-the-art imaging, digital dentistry tools, and precision diagnostics.',
    href: '/services/advanced-technology/',
    photo: '/images/service-advanced-tech.png',
    photoAlt: '3D digital rendering of dental anatomy',
  },
  {
    name: 'Galleri® Cancer Detection',
    description: 'First in Minnesota to offer the Galleri® multi-cancer early detection blood test.',
    href: '/services/galleri-oral-cancer-detection/',
    photo: null,
    photoAlt: '',
  },
];

const testimonials = [
  {
    quote: "I've been a patient of Dr. Sudit's for over 25 years. His commitment to excellence and the genuine warmth of his team keep me coming back. There is truly no one else I would trust with my family's dental care.",
    author: "Sarah M.",
    location: "Minnetonka",
    stars: 5,
  },
  {
    quote: "I had a dental emergency on a Friday afternoon and they got me in immediately. The care was exceptional, and the entire team made what could have been a very stressful situation completely comfortable. I can't recommend them enough.",
    author: "James R.",
    location: "Eden Prairie",
    stars: 5,
  },
  {
    quote: "Dr. Sudit is in a league of his own. The level of personal attention, the spotless and beautiful office, the way every single team member treats you — it is unlike any dental experience I've ever had.",
    author: "Carol L.",
    location: "Wayzata",
    stars: 5,
  },
];

const patientResources = [
  {
    title: 'New Patients',
    description: 'Everything you need to know before your first visit — what to expect and how to prepare.',
    href: '/patients/new-patients/',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  },
  {
    title: 'Patient Forms',
    description: 'Access and complete your paperwork in advance through our patient portal.',
    href: '/patients/patient-forms/',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
  },
  {
    title: 'Insurance & Payment',
    description: 'We\'re out-of-network fee-for-service and accept CareCredit, Cherry, and offer a prepay discount.',
    href: '/patients/insurance-payment/',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>`,
  },
  {
    title: 'FAQ',
    description: 'Answers to common questions about our services, technology, and practice philosophy.',
    href: '/patients/faq/',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>`,
  },
];
---

<BaseLayout
  title="Center for Smile Enhancement | Dr. Michael Sudit, DDS | Minnetonka, MN"
  description="Boutique dental care in Minnetonka, MN. Dr. Michael Sudit offers cosmetic, general, implant, and aesthetic dentistry with Disney-inspired service for 35+ years."
>
  <Header />

  <main id="main-content">
    <!-- ── Hero ──────────────────────────────────────── -->
    <section aria-label="Introduction" style="background-color: #ffffff; padding-top: 5rem; padding-bottom: 5rem;">
      <div class="site-container">
        <div class="hero-layout">

          <!-- Text content -->
          <div class="hero-text">
            <span class="section-eyebrow">Minnetonka, MN &nbsp;·&nbsp; Boutique Dental Care</span>
            <h1 class="hero-h1">
              Excellence Is the Baseline.<br />
              Service Is the Differentiator.
            </h1>
            <p style="font-size: 1.0625rem; line-height: 1.75; color: var(--color-text-muted); margin-top: 1.5rem; margin-bottom: 2.25rem; max-width: 36rem;">
              For over 35 years, Dr. Michael Sudit has delivered boutique dental care in Minnetonka defined by clinical excellence and a patient experience inspired by the world's finest hospitality brands.
            </p>
            <div style="display: flex; flex-wrap: wrap; gap: 1rem; margin-bottom: 2.5rem;">
              <a href="/schedule/" class="btn btn-primary">Schedule an Appointment</a>
              <a href="/about/" class="btn btn-outline">Meet Dr. Sudit</a>
            </div>
            <!-- Trust micro-bullets -->
            <div class="hero-trust-row">
              <span class="hero-trust-item">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                272 Five-Star Reviews
              </span>
              <span class="hero-trust-item">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                35+ Years of Practice
              </span>
              <span class="hero-trust-item">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                Top Dentist Hall of Fame
              </span>
            </div>
          </div>

          <!-- Doctor photo -->
          <div class="hero-photo-wrap">
            <div class="hero-photo-inner">
              <img
                src="/images/hero-patient.jpg"
                alt="Patient with a confident smile at Center for Smile Enhancement"
                width="2500"
                height="1664"
                loading="eager"
                fetchpriority="high"
                style="width: 100%; height: 100%; object-fit: cover; object-position: center 20%;"
              />
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ── Trust Strip ────────────────────────────────── -->
    <section
      aria-label="Practice highlights"
      style="background-color: var(--color-surface); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border);"
    >
      <div class="site-container" style="padding-top: 2.5rem; padding-bottom: 2.5rem;">
        <div class="trust-grid">
          <div class="trust-item">
            <span class="trust-number">272</span>
            <span class="trust-label">Five-Star Google Reviews</span>
          </div>
          <div class="trust-item">
            <span class="trust-number">35+</span>
            <span class="trust-label">Years in Practice</span>
          </div>
          <div class="trust-item">
            <span class="trust-number">Hall&nbsp;of&nbsp;Fame</span>
            <span class="trust-label">Top Dentist — Minneapolis St. Paul Mag.</span>
          </div>
          <div class="trust-item">
            <span class="trust-number">Since&nbsp;2001</span>
            <span class="trust-label">Disney Institute&nbsp;Trained</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ── What Sets Us Apart ─────────────────────────── -->
    <section aria-labelledby="differentiators-heading" style="background-color: #ffffff;">
      <div class="site-container section-py">
        <div style="text-align: center; max-width: 36rem; margin: 0 auto 3.5rem;">
          <span class="section-eyebrow">Our Difference</span>
          <h2 id="differentiators-heading" class="section-heading" style="font-size: clamp(1.75rem, 3vw, 2.5rem);">
            What Sets Us Apart
          </h2>
        </div>

        <div class="features-grid">
          <!-- Card 1: Disney Difference -->
          <div class="card" style="border-top: 3px solid var(--color-brand-light);">
            <div class="feature-icon-wrap">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            </div>
            <h3 style="font-size: 1.125rem; font-weight: 600; margin-bottom: 0.625rem;">The Disney Difference</h3>
            <p style="font-size: 0.9375rem; line-height: 1.7; color: var(--color-text-muted);">
              Since 2001, our practice has been infused with the Disney Institute's customer service philosophy. Every touchpoint — from your first call to your final follow-up — is designed to exceed your expectations.
            </p>
          </div>

          <!-- Card 2: Total Health Connection -->
          <div class="card" style="border-top: 3px solid var(--color-brand-light);">
            <div class="feature-icon-wrap">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
              </svg>
            </div>
            <h3 style="font-size: 1.125rem; font-weight: 600; margin-bottom: 0.625rem;">The Total Health Connection</h3>
            <p style="font-size: 0.9375rem; line-height: 1.7; color: var(--color-text-muted);">
              We treat the whole person, not just the teeth. Your oral health is directly connected to your systemic and chronic health outcomes — a philosophy that guides every diagnosis and treatment decision we make.
            </p>
          </div>

          <!-- Card 3: Boutique Care -->
          <div class="card" style="border-top: 3px solid var(--color-brand-light);">
            <div class="feature-icon-wrap">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
              </svg>
            </div>
            <h3 style="font-size: 1.125rem; font-weight: 600; margin-bottom: 0.625rem;">Every Patient Is a VIP</h3>
            <p style="font-size: 0.9375rem; line-height: 1.7; color: var(--color-text-muted);">
              VIP means Very Individual Patient. We take the time to understand your unique goals, preferences, and concerns — because one-size-fits-all has never been part of our vocabulary.
            </p>
          </div>

          <!-- Card 4: Galleri -->
          <div class="card" style="border-top: 3px solid var(--color-brand-light);">
            <div class="feature-icon-wrap">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
              </svg>
            </div>
            <h3 style="font-size: 1.125rem; font-weight: 600; margin-bottom: 0.625rem;">Galleri® Cancer Detection</h3>
            <p style="font-size: 0.9375rem; line-height: 1.7; color: var(--color-text-muted);">
              We are the first dental practice in Minnesota to offer the Galleri® multi-cancer early detection blood test — a powerful, proactive tool for protecting your long-term health.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Practice Interior ─────────────────────────── -->
    <div style="position: relative; height: clamp(200px, 28vw, 400px); overflow: hidden;">
      <img
        src="/images/interior-office.jpg"
        alt="Center for Smile Enhancement reception area in Minnetonka, MN"
        width="2500"
        height="1664"
        loading="eager"
        decoding="async"
        style="width: 100%; height: 100%; object-fit: cover; object-position: center 35%;"
      />
      <div style="
        position: absolute;
        inset: 0;
        background: linear-gradient(to right, rgba(10,25,55,0.58) 0%, rgba(10,25,55,0.22) 55%, transparent 100%);
        display: flex;
        align-items: center;
      ">
        <div style="max-width: 30rem; padding: 2rem clamp(1.5rem, 5vw, 4rem); color: white;">
          <p style="font-family: var(--font-display); font-size: clamp(1.0625rem, 1.8vw, 1.5rem); font-weight: 600; line-height: 1.45; margin-bottom: 0.625rem;">
            A boutique experience in the heart of Minnetonka
          </p>
          <p style="font-size: 0.875rem; color: rgba(255,255,255,0.8); line-height: 1.65; letter-spacing: 0.01em;">
            10500 Wayzata Blvd &nbsp;·&nbsp; Mon–Thu 8am–5pm, Fri 8am–12pm
          </p>
        </div>
      </div>
    </div>

    <!-- ── Services ───────────────────────────────────── -->
    <section aria-labelledby="services-heading" style="background-color: var(--color-surface);">
      <div class="site-container section-py">
        <div style="text-align: center; max-width: 36rem; margin: 0 auto 3rem;">
          <span class="section-eyebrow">Comprehensive Care</span>
          <h2 id="services-heading" class="section-heading" style="font-size: clamp(1.75rem, 3vw, 2.5rem);">
            All Your Dental Needs, Under One Roof
          </h2>
          <p style="margin-top: 1rem; font-size: 0.9375rem; color: var(--color-text-muted); line-height: 1.7;">
            From routine cleanings to full smile makeovers, Dr. Sudit and his team provide a comprehensive range of dental and aesthetic services.
          </p>
        </div>

        <div class="svc-grid">
          {services.map((service) => (
            <a href={service.href} class={`svc-tile${!service.photo ? ' svc-tile--no-photo' : ''}`}>
              {service.photo && (
                <img
                  src={service.photo}
                  alt={service.photoAlt}
                  loading="lazy"
                  decoding="async"
                  class="svc-tile__img"
                />
              )}
              <div class="svc-tile__overlay" />
              <div class="svc-tile__content">
                <h3 class="svc-tile__name">{service.name}</h3>
                <p class="svc-tile__desc">{service.description}</p>
                <span class="svc-tile__cta" aria-hidden="true">
                  Learn more
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </span>
              </div>
              <span class="sr-only">Learn more about {service.name}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Testimonials ───────────────────────────────── -->
    <section aria-labelledby="testimonials-heading" style="background-color: #ffffff;">
      <div class="site-container section-py">
        <div style="text-align: center; max-width: 36rem; margin: 0 auto 3.5rem;">
          <span class="section-eyebrow">Patient Stories</span>
          <h2 id="testimonials-heading" class="section-heading" style="font-size: clamp(1.75rem, 3vw, 2.5rem);">
            What Our Patients Are Saying
          </h2>
          <p style="margin-top: 1rem; font-size: 0.9375rem; color: var(--color-text-muted);">
            272 five-star Google reviews and counting.
          </p>
        </div>

        <div class="testimonials-grid">
          {testimonials.map((t) => (
            <div class="testimonial-card">
              <!-- Stars -->
              <div style="display: flex; gap: 3px; margin-bottom: 1.25rem;" aria-label={`${t.stars} out of 5 stars`}>
                {Array.from({ length: t.stars }).map(() => (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                ))}
              </div>
              <blockquote>
                <p style="font-size: 0.9375rem; line-height: 1.75; color: var(--color-text-base); font-style: italic; margin-bottom: 1.5rem;">
                  "{t.quote}"
                </p>
                <footer style="font-size: 0.875rem; font-weight: 500; color: var(--color-primary);">
                  {t.author} &nbsp;<span style="font-weight: 400; color: var(--color-text-muted);">— {t.location}</span>
                </footer>
              </blockquote>
            </div>
          ))}
        </div>

        <div style="text-align: center; margin-top: 2.5rem;">
          <a href="/patients/reviews/" class="btn btn-outline">Read All Reviews</a>
        </div>
      </div>
    </section>

    <!-- ── Patient Resources ──────────────────────────── -->
    <section aria-labelledby="resources-heading" style="background-color: var(--color-brand-light);">
      <div class="site-container section-py">
        <div style="text-align: center; max-width: 36rem; margin: 0 auto 3rem;">
          <span class="section-eyebrow" style="color: var(--color-primary);">For Our Patients</span>
          <h2 id="resources-heading" class="section-heading" style="font-size: clamp(1.75rem, 3vw, 2.25rem);">
            Patient Resources
          </h2>
        </div>

        <div class="resources-grid">
          {patientResources.map((res) => (
            <a href={res.href} class="resource-card">
              <div class="resource-icon" set:html={res.icon} />
              <h3 style="font-size: 1.0625rem; font-weight: 600; margin-bottom: 0.5rem;">{res.title}</h3>
              <p style="font-size: 0.875rem; line-height: 1.6; color: var(--color-text-muted);">{res.description}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Final CTA ──────────────────────────────────── -->
    <section
      aria-labelledby="cta-heading"
      style="background-color: #ffffff; padding-top: 5rem; padding-bottom: 5rem; text-align: center; border-top: 1px solid var(--color-border);"
    >
      <div class="site-container">
        <span class="section-eyebrow">Minnetonka, MN</span>
        <h2
          id="cta-heading"
          style="font-family: var(--font-display); font-size: clamp(1.875rem, 3.5vw, 3rem); font-weight: 700; color: var(--color-primary); margin-bottom: 1.25rem; line-height: 1.2;"
        >
          Ready to Experience the Difference?
        </h2>
        <p style="font-size: 1rem; color: var(--color-text-muted); max-width: 32rem; margin: 0 auto 2.25rem; line-height: 1.7;">
          New and returning patients are welcome. Call us or schedule online — we look forward to exceeding your expectations.
        </p>
        <div style="display: flex; flex-wrap: wrap; gap: 1rem; justify-content: center;">
          <a href="/schedule/" class="btn btn-primary">Schedule an Appointment</a>
          <a href="tel:9525939310" class="btn btn-outline">Call 952-593-9310</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  /* ── Hero ───────────────────────────────────────────── */
  .hero-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }
  @media (min-width: 768px) {
    .hero-layout {
      grid-template-columns: 3fr 2fr;
      gap: 4rem;
    }
  }
  @media (min-width: 1024px) {
    .hero-layout {
      gap: 5rem;
    }
  }

  .hero-h1 {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1.15;
    margin-top: 0.5rem;
  }

  .hero-trust-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
  }
  .hero-trust-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-muted);
    letter-spacing: 0.01em;
  }
  .hero-trust-item svg {
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .hero-photo-wrap {
    position: relative;
  }
  .hero-photo-inner {
    background-color: var(--color-surface);
    height: 480px;
    overflow: hidden;
  }
  @media (min-width: 1024px) {
    .hero-photo-inner { height: 560px; }
  }
  .hero-photo-caption {
    margin-top: 0.875rem;
    font-size: 0.8125rem;
    font-weight: 400;
    color: var(--color-text-muted);
    text-align: center;
    letter-spacing: 0.03em;
  }

  /* ── Trust Strip ────────────────────────────────────── */
  .trust-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    text-align: center;
  }
  @media (min-width: 768px) {
    .trust-grid { grid-template-columns: repeat(4, 1fr); }
  }

  .trust-item { display: flex; flex-direction: column; gap: 0.375rem; }
  .trust-number {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1;
  }
  .trust-label {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
